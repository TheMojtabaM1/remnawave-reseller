# ─────────────────────────────────────────────────────────────
# Remnawave Reseller Panel  |  Environment configuration
# Copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# Application
APP_NAME="Remnawave Reseller"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://agent.example.com:8443   # admin panel URL (host:port)
APP_KEY=                       # 32+ random chars, set by installer
APP_TIMEZONE=Asia/Tehran

# Database (MySQL / MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=remnawave_reseller
DB_USER=remnawave_reseller
DB_PASS=

# Remnawave panel API
RW_BASE_URL=https://remna.example.com      # base panel URL, WITHOUT trailing /api
RW_API_TOKEN=                              # Remnawave API token (Bearer)
RW_TIMEOUT=30
# Optional extra headers some reverse-proxy setups require (JSON object), e.g. {"X-Forwarded-For":"..."}
RW_EXTRA_HEADERS=

# Defaults / behaviour (also editable in Settings UI)
DEFAULT_TRAFFIC_STRATEGY=NO_RESET          # NO_RESET | DAY | WEEK | MONTH
CLEANUP_GRACE_DAYS=3
LOW_BALANCE_THRESHOLD=50000

# Backups
BACKUP_KEEP=14                             # how many daily backups to retain
