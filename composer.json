{
    "name": "themojtabam/remnawave-reseller",
    "description": "Remnawave Reseller — Agent Management Panel",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.8",
        "vlucas/phpdotenv": "^5.6",
        "endroid/qr-code": "^5.0",
        "phpoffice/phpspreadsheet": "^2.1",
        "mpdf/mpdf": "^8.2",
        "morilog/jalali": "^3.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
